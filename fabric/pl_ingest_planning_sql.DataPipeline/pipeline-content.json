        "name": "lookup_current_planning_watermark",
        "dependsOn": []
      },
      {
        "type": "IfCondition",
        "typeProperties": {
          "expression": {
            "value": "@greater(\n    ticks(activity('lookup_current_planning_watermark').output.firstRow.CurrentWatermark),\n    ticks(activity('lookup_previous_planning_watermark').output.firstRow.LastWatermarkValue)\n)",
            "type": "Expression"
          },
          "ifTrueActivities": [
            {
              "type": "Copy",
              "typeProperties": {
                "source": {
                  "type": "SqlServerSource",
                  "sqlReaderQuery": "@concat(\n    'SELECT * FROM dbo.PlanningApplication ',\n    'WHERE RecordLastUpdatedAt > CONVERT(datetime2(6), ''',\n    activity('lookup_previous_planning_watermark').output.firstRow.LastWatermarkValue,\n    ''', 126) ',\n    'AND RecordLastUpdatedAt <= CONVERT(datetime2(6), ''',\n    activity('lookup_current_planning_watermark').output.firstRow.CurrentWatermark,\n    ''', 126)'\n)",
